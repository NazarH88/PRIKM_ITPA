	<item>
		<title>End of Life: Changes to Eclipse Jetty and CometD</title>
		<link>https://webtide.com/end-of-life-changes-to-eclipse-jetty-and-cometd/</link>
					<comments>https://webtide.com/end-of-life-changes-to-eclipse-jetty-and-cometd/#respond</comments>
		
		<dc:creator><![CDATA[Jesse McConnell]]></dc:creator>
